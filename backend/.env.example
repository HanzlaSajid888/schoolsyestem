PORT=5000

# MongoDB Atlas (required)
# 1. Atlas → your cluster → Connect → Drivers
# 2. Copy the connection string and replace <password> with your DB user password
# 3. Set the database name (e.g. edustream_sms) before the "?" in the URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/edustream_sms?retryWrites=true&w=majority

NODE_ENV=development
CORS_ORIGIN=*
